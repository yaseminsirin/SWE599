DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=jobs_db
POSTGRES_USER=jobs_user
POSTGRES_PASSWORD=jobs_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

ADZUNA_BASE_URL=https://api.adzuna.com/v1/api/jobs
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us

USAJOBS_BASE_URL=https://data.usajobs.gov/api
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=your-email@example.com

REMOTIVE_BASE_URL=https://remotive.com/api

INGEST_SCHEDULE_TIMEZONE=Europe/Istanbul
INGEST_SCHEDULE_HOUR=3
INGEST_SCHEDULE_MINUTE=0

INGEST_PAGE_SIZE=50
INGEST_MAX_PAGES=50
INGEST_PAGE_SIZE_ADZUNA=50
INGEST_MAX_PAGES_ADZUNA=50
INGEST_PAGE_SIZE_USAJOBS=500
INGEST_MAX_PAGES_USAJOBS=20
INGEST_PAGE_SIZE_REMOTIVE=100
INGEST_MAX_PAGES_REMOTIVE=5

EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_STRICT_PROVIDER=true
EMBEDDING_BATCH_SIZE=50
EMBEDDING_MAX_JOBS_PER_RUN=500
EMBEDDING_SLEEP_SECONDS=0
EMBEDDING_TECH_ONLY=true
# Optional legacy: EMBEDDING_PROVIDER=gemini EMBEDDING_DIMENSION=768
SEMANTIC_TECH_ONLY=true
SEMANTIC_SEARCH_CANDIDATE_POOL=100
SEMANTIC_RERANK_WEIGHT_SEMANTIC=0.7
SEMANTIC_RERANK_WEIGHT_LEXICAL=0.3
# Legacy alias: EMBEDDING_MODEL_NAME=hashing-v1 (when EMBEDDING_PROVIDER=local)
RANKING_WEIGHT_KEYWORD=0.5
RANKING_WEIGHT_SEMANTIC=0.3
RANKING_WEIGHT_CLICK=0.2

# Email — alert delivery uses Brevo REST API (BREVO_API_KEY), not SMTP.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@example.com
DEFAULT_FROM_NAME=JobSense AI
BREVO_API_KEY=
BREVO_API_TIMEOUT_SECONDS=30
ALERT_DEFAULT_EMAIL=
SITE_URL=http://localhost:8000

# Production (DigitalOcean + Brevo API) — set on server .env only:
# DEFAULT_FROM_EMAIL=yaseminsirin322@gmail.com
# BREVO_API_KEY=your-brevo-api-key
# SITE_URL=http://104.248.113.186:8000
ALERT_SCHEDULE_HOUR=
ALERT_SCHEDULE_MINUTE=0

# RAG alert emails
# Production (DigitalOcean): use Gemini if you have a key; otherwise leave LLM_PROVIDER empty for fallback.
# Local demo: Ollama (see docs/RAG_ALERTS.md)
LLM_PROVIDER=
LLM_MODEL=gemini-2.0-flash
LLM_TIMEOUT_SECONDS=30
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434
